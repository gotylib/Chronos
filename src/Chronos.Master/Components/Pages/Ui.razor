@page "/ui/app"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav

<h2>Chronos.Master Control Panel</h2>

<p>
    <button @onclick="ReloadAll">Refresh</button>
</p>

<h3>Agents</h3>
<table class="table">
    <thead>
    <tr>
        <th>Agent</th>
        <th>URL</th>
        <th>Location</th>
        <th>CPU</th>
        <th>Memory</th>
        <th>Disk</th>
        <th>Heartbeat</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var a in Agents)
    {
        <tr>
            <td>@a.AgentId</td>
            <td>@a.BaseUrl</td>
            <td>@a.Location</td>
            <td>@a.CpuPercent.ToString("F1")%</td>
            <td>@a.MemoryPercent.ToString("F1")%</td>
            <td>@a.DiskPercent.ToString("F1")%</td>
            <td>@a.LastHeartbeatUtc.ToLocalTime()</td>
        </tr>
    }
    </tbody>
</table>

<h3>Cluster Projects</h3>
<table class="table">
    <thead>
    <tr>
        <th>Project</th>
        <th>Agent</th>
        <th>Updated</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var p in Projects)
    {
        <tr>
            <td>@p.ProjectName</td>
            <td>@p.AgentId</td>
            <td>@p.UpdatedUtc.ToLocalTime()</td>
            <td>
                <button @onclick="() => StopProject(p.ProjectName, false)">Stop</button>
                <button @onclick="() => RestartProject(p.ProjectName, false)">Restart</button>
                <button @onclick="() => LoadVolumes(p.ProjectName)">Volumes</button>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (!string.IsNullOrWhiteSpace(SelectedProject))
{
    <h4>Volumes: @SelectedProject</h4>
    <ul>
        @foreach (var v in SelectedVolumes)
        {
            <li>@v</li>
        }
    </ul>
}

<style>
    .table { border-collapse: collapse; width: 100%; }
    .table th, .table td { border: 1px solid #ddd; padding: 6px; font-size: 13px; }
    .table th { background: #f2f2f2; }
    button { margin-right: 6px; }
</style>

@code {
    private List<AgentInfo> Agents { get; set; } = [];
    private List<ProjectPlacementInfo> Projects { get; set; } = [];
    private string? SelectedProject { get; set; }
    private List<string> SelectedVolumes { get; set; } = [];
    private string? ApiKey { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("apiKey", out var v))
            ApiKey = v.FirstOrDefault();
        await ReloadAll();
    }

    private async Task ReloadAll()
    {
        using var http = HttpFactory.CreateClient();
        Agents = await http.GetFromJsonAsync<List<AgentInfo>>(WithApiKey("/agents")) ?? [];
        Projects = await http.GetFromJsonAsync<List<ProjectPlacementInfo>>(WithApiKey("/cluster/projects")) ?? [];
        StateHasChanged();
    }

    private async Task StopProject(string projectName, bool removeVolumes)
    {
        using var http = HttpFactory.CreateClient();
        using var req = new HttpRequestMessage(HttpMethod.Post, WithApiKey($"/cluster/projects/{Uri.EscapeDataString(projectName)}/stop?removeVolumes={removeVolumes}"));
        _ = await http.SendAsync(req);
        await ReloadAll();
    }

    private async Task RestartProject(string projectName, bool removeVolumes)
    {
        using var http = HttpFactory.CreateClient();
        using var req = new HttpRequestMessage(HttpMethod.Post, WithApiKey($"/cluster/projects/{Uri.EscapeDataString(projectName)}/restart?removeVolumes={removeVolumes}"));
        _ = await http.SendAsync(req);
        await ReloadAll();
    }

    private async Task LoadVolumes(string projectName)
    {
        using var http = HttpFactory.CreateClient();
        SelectedProject = projectName;
        SelectedVolumes = await http.GetFromJsonAsync<List<string>>(WithApiKey($"/cluster/projects/{Uri.EscapeDataString(projectName)}/volumes")) ?? [];
        StateHasChanged();
    }

    private string WithApiKey(string path)
    {
        var combined = path;
        if (string.IsNullOrWhiteSpace(ApiKey))
            return Nav.ToAbsoluteUri(combined).ToString();

        var separator = path.Contains('?') ? "&" : "?";
        combined = $"{path}{separator}apiKey={Uri.EscapeDataString(ApiKey)}";
        return Nav.ToAbsoluteUri(combined).ToString();
    }
}

