# Copy to /etc/chronos-agent/environment (chmod 640, root:chronos) and adjust values.
# systemd loads this file for the chronos-agent service.

# Listen address (required for remote access)
ASPNETCORE_URLS=http://0.0.0.0:5050

# Where compose projects and .chronos state live
CHRONOS_AGENT_APP_PATH=/var/lib/chronos-agent

# Optional: require X-API-Key on HTTP requests
# CHRONOS_AGENT_API_KEY=your-secret-key

# docker compose: omit or set to "auto" to probe docker compose (v2) vs docker-compose (v1)
# CHRONOS_AGENT_DOCKER_COMPOSE_EXECUTABLE=auto
CHRONOS_AGENT_DOCKER_EXECUTABLE=docker

# Optional: register with Chronos.Master
# CHRONOS_MASTER_URL=http://master.example:5000
# CHRONOS_AGENT_BASE_URL=http://this-host.example:5050
# CHRONOS_MASTER_API_KEY=
# CHRONOS_AGENT_LOCATION=eu-west
